# mise configuration for {{ project_name }}
# https://mise.jdx.dev/configuration.html

[env]
_.file = [".env"]
CODEX_HOME = { value = ".codex", path = true }

# This block will handle the linking of 
# agent files to the main AGENTS.md file.
#
# TODO: Ensure this works for all levels of nesting.
# i.e. All linked agent files MUST be siblings at 
# any given level of nesting.
[hooks]
enter = '{{config_root}}/.mise/scripts/link-agentfiles.sh'

[[watch_files]]
patterns = ["AGENTS.md"]
task = "link-agentfiles"

[tasks.link-agentfiles]
description = "Symlink all agent files to AGENTS.md"
run = ".mise/scripts/link-agentfiles.sh"

# Auto-activate a Python venv when one exists at ./.venv.
# `create = false` means mise will not create one on its own,
# and the directive is silently ignored when the path is absent.
_.python.venv = { path = ".venv", create = false }
