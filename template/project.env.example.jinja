# {{ project_name }} Environment Configuration
# Copy to .env and fill in actual values

{% if uses_event_bus %}
# Bloodbank Event Bus
BLOODBANK_URL=amqp://localhost:5672
BLOODBANK_EXCHANGE={{ project_slug }}_events
{% endif %}

{% if additional_services %}
{% for service in additional_services.split(',') %}
{% set service_name = service.strip().upper() %}
# {{ service_name }}
{{ service_name }}_HOST=localhost
{{ service_name }}_PORT=
{{ service_name }}_DATABASE={{ project_slug }}
{% endfor %}
{% endif %}

{% if has_hardware %}
# Hardware Configuration
HARDWARE_HOSTNAME={{ hardware_hostname }}
HARDWARE_PLATFORM={{ hardware_platform }}
{% endif %}

# API Keys (if needed)
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
