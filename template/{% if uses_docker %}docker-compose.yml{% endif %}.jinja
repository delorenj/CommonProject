# Docker Compose configuration for {{ project_name }}
version: '3.8'

services:
  {{ project_slug }}:
    build:
      context: .
      dockerfile: Dockerfile
    container_name: {{ project_slug }}
    environment:
      - PLANE_PROJECT_ID={{ project_project_id }}
{% if uses_event_bus %}
      - BLOODBANK_URL=${BLOODBANK_URL:-amqp://bloodbank:5672}
{% endif %}
    volumes:
      - ./:/app
{% if primary_language == 'python' %}
      - uv-cache:/root/.cache/uv
{% elif primary_language == 'typescript' %}
      - bun-cache:/root/.bun
{% endif %}
    restart: unless-stopped
{% if uses_event_bus %}
    depends_on:
      - bloodbank
{% endif %}
{% if additional_services %}
{% for service in additional_services.split(',') %}
{% set service_name = service.strip() %}
      - {{ service_name }}
{% endfor %}
{% endif %}

{% if uses_event_bus %}
  bloodbank:
    image: rabbitmq:3-management-alpine
    container_name: {{ project_slug }}_bloodbank
    ports:
      - "5672:5672"
      - "15672:15672"
    environment:
      - RABBITMQ_DEFAULT_USER=admin
      - RABBITMQ_DEFAULT_PASS=admin
    volumes:
      - rabbitmq-data:/var/lib/rabbitmq
    restart: unless-stopped
{% endif %}

{% if additional_services %}
{% for service in additional_services.split(',') %}
{% set service_name = service.strip() %}
{% if service_name == 'postgres' %}
  postgres:
    image: postgres:16-alpine
    container_name: {{ project_slug }}_postgres
    environment:
      - POSTGRES_DB={{ project_slug }}
      - POSTGRES_USER=admin
      - POSTGRES_PASSWORD=admin
    volumes:
      - postgres-data:/var/lib/postgresql/data
    ports:
      - "5432:5432"
    restart: unless-stopped
{% elif service_name == 'redis' %}
  redis:
    image: redis:7-alpine
    container_name: {{ project_slug }}_redis
    ports:
      - "6379:6379"
    volumes:
      - redis-data:/data
    restart: unless-stopped
{% elif service_name == 'qdrant' %}
  qdrant:
    image: qdrant/qdrant:latest
    container_name: {{ project_slug }}_qdrant
    ports:
      - "6333:6333"
      - "6334:6334"
    volumes:
      - qdrant-data:/qdrant/storage
    restart: unless-stopped
{% endif %}
{% endfor %}
{% endif %}

volumes:
{% if primary_language == 'python' %}
  uv-cache:
{% elif primary_language == 'typescript' %}
  bun-cache:
{% endif %}
{% if uses_event_bus %}
  rabbitmq-data:
{% endif %}
{% if additional_services %}
{% for service in additional_services.split(',') %}
{% set service_name = service.strip() %}
  {{ service_name }}-data:
{% endfor %}
{% endif %}
